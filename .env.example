# Database Connection
# Replace with your actual PostgreSQL connection string from Neon/Supabase
DATABASE_URL="postgresql://username:password@host.region.provider.com/dbname?sslmode=require"

# JWT Secret for session management
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET="change-this-to-a-very-long-random-string-in-production-min-32-chars"

# Optional: Node Environment
NODE_ENV="development"
